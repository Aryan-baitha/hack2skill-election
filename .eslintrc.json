{
  "env": {
    "browser": true,
    "es2022": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "script"
  },
  "rules": {
    "no-console": "error",
    "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }],
    "no-param-reassign": "error",
    "prefer-const": "error",
    "no-var": "error",
    "eqeqeq": ["error", "always"],
    "no-eval": "error",
    "no-implied-eval": "error",
    "no-new-func": "error",
    "no-alert": "warn",
    "strict": ["error", "global"],
    "curly": "error",
    "no-empty": "error",
    "no-unreachable": "error",
    "complexity": ["warn", 15]
  },
  "globals": {
    "BarcodeDetector": "readonly",
    "SpeechRecognition": "readonly",
    "webkitSpeechRecognition": "readonly"
  }
}
